{
	"extends": "@mingull/typescript-config/nextjs.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@mingull/ui/*": [
				"../../packages/ui/src/*"
			]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"allowArbitraryExtensions": true
	},
	"include": [
		"next-env.d.ts",
		"next.config.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts"
, "../api/drizzle.config.ts"	],
	"exclude": [
		"node_modules"
	]
}
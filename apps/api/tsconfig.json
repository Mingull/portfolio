{
  "extends": "@mingull/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowArbitraryExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
, "../../packages/database/src/client.ts", "../../packages/database/src/relations.ts", "../../packages/database/drizzle.config.ts"  ],
  "exclude": [
    "node_modules"
  ]
}
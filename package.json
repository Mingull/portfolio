{
	"name": "mingull-portfolio",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo run check-types",
		"db:logs": "docker compose logs -f mysql phpmyadmin",
		"db:seed": "node --env-file=.env --import=tsx packages/database/src/seed.ts"
	},
	"devDependencies": {
		"dotenv-cli": "^11.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"turbo": "^2.8.20",
		"typescript": "6.0.2"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24"
	}
}

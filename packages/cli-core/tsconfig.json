{
  "extends": "@mingull/typescript-config/node-library.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "sourceMap": false,
    "declarationMap": false,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}